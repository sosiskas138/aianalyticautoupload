# Подключение к БД (вариант 1 — одной строкой)
# DATABASE_URL=postgresql://user:password@localhost:5432/telemarketing_analytics

# Подключение к БД (вариант 2 — по частям)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=telemarketing_analytics

# Порт сервиса
PORT=3002

# Автосоздание проекта при первом вебхуке от новой организации
WEBHOOK_AUTO_CREATE_PROJECT=1
